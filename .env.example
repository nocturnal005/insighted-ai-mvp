# Demo/auth mode
DEMO_MODE=true

# AI mode
AI_MODE=mock
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1
OPENAI_TEXT_MODEL=gpt-4.1

# Braille OCR provider options:
# mock | openai_vision_draft | external_braille_ocr
BRAILLE_OCR_PROVIDER=mock
BRAILLE_OCR_ENDPOINT=
BRAILLE_OCR_API_KEY=

# File processing
MAX_UPLOAD_MB=10
ALLOWED_UPLOAD_TYPES=image/png,image/jpeg,image/jpg,application/pdf

# Safety
ALLOW_REAL_PUPIL_DATA=false
