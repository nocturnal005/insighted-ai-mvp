# Demo/auth mode
DEMO_MODE=true

# AI mode
AI_MODE=mock
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_TEXT_MODEL=gpt-4.1
# Keep interactive requests within normal serverless/action budgets.
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=1

# Braille OCR provider options:
# abc_openai_review | abc_braille_web | mock | openai_vision_draft | external_braille_ocr
# Mock mode is fully offline. Set AI_MODE=real before selecting a real OCR provider.
# abc_openai_review keeps ABC as the primary draft and uses OpenAI only to flag
# discrepancies; it requires OPENAI_API_KEY. No suggestion is applied automatically.
BRAILLE_OCR_PROVIDER=mock
# ABC Braille defaults. Its public web translator has no documented JSON API, so this
# adapter is provisional and should be used only with ABC's permission in production.
ABC_BRAILLE_BASE_URL=https://www.abcbraille.com
ABC_BRAILLE_LANGUAGE_TABLE=en-ueb-g2.ctb
ABC_BRAILLE_TIMEOUT_MS=120000
BRAILLE_OCR_ENDPOINT=
BRAILLE_OCR_API_KEY=
# Request timeout (ms) for the external Braille OCR endpoint.
BRAILLE_OCR_TIMEOUT_MS=30000

# Neon Postgres. Vercel Marketplace normally supplies DATABASE_URL automatically.
# POSTGRES_URL and NEON_DATABASE_URL are also accepted for existing environments.
DATABASE_URL=
POSTGRES_URL=
NEON_DATABASE_URL=

# Optional Liblouis back-translation (Braille cells -> print text; NOT image OCR).
# Disabled by default so the build never depends on a native Liblouis binary.
# When enabled, LIBLOUIS_COMMAND should point at a lou_translate-style CLI.
LIBLOUIS_ENABLED=false
LIBLOUIS_COMMAND=
LIBLOUIS_TABLE=en-ueb-g2.ctb
# Required for Unicode Braille patterns (U+2800-U+28FF) returned by the primary OCR.
LIBLOUIS_DISPLAY_TABLE=unicode.dis
LIBLOUIS_TIMEOUT_MS=5000

# File processing
MAX_UPLOAD_MB=10
ALLOWED_UPLOAD_TYPES=image/png,image/jpeg,image/jpg,application/pdf

# Safety
# Keep false for demos/pilots. When false, pupil-linked tasks run through a real provider
# raise a high-severity warning; identifiable pupil data is never sent to a real provider.
ALLOW_REAL_PUPIL_DATA=false
